# Modem
MODEM_DEVICE=/dev/ttyUSB0
MODEM_BAUD_RATE=115200
MODEM_POLL_SECONDS=10

# MQTT broker
MQTT_BROKER=tcp://your-broker:1883
MQTT_CLIENT_ID=sms2mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# Forward received SMS to this number (optional, leave empty to disable)
FORWARD_TO=

# Topics (defaults shown, override if needed)
MQTT_TOPIC_INBOX=sms2mqtt/inbox
MQTT_TOPIC_SEND=sms2mqtt/send
MQTT_TOPIC_STATUS=sms2mqtt/status
MQTT_TOPIC_MODEM=sms2mqtt/modem
